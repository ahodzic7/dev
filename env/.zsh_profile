export XDG_CONFIG_HOME=$HOME/.config
export N_PREFIX="$HOME/.local/n"
VIM="nvim"
## If I am in WSL, need to use windows git:
alias wgit="/mnt/c/Program\ Files/Git/cmd/git.exe"

PERSONAL=$XDG_CONFIG_HOME/personal
DEV_ENV=$HOME/dev
for i in `find -L $PERSONAL`; do
    source $i
done

## All that sweet sweet fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

export GIT_EDITOR=$VIM
export DEV_ENV_HOME="$HOME/personal/dev"

dev_env() {

}

# Where should I put you?
bindkey -s ^f "tmux-sessionizer\n"
bindkey -v

bindkey -M viins -s '^f' 'tmux-sessionizer\n'
bindkey -M vicmd -s '^f' 'tmux-sessionizer\n'

# claude-finder (in-tmux the C-g root bind in tmux.conf wins; this is the bare-terminal fallback)
bindkey -s ^g "claude-finder\n"
bindkey -M viins -s '^g' 'claude-finder\n'
bindkey -M vicmd -s '^g' 'claude-finder\n'

catr() {
    tail -n "+$1" $3 | head -n "$(($2 - $1 + 1))"
}

cat1Line() {
    cat $1 | tr -d "\n"
}


addToPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$PATH:$1
    fi
}

addToPathFront() {
    if [[ ! -z "$2" ]] || [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}

addToPathFront $HOME/.local/apps
addToPathFront $HOME/.local/scripts
addToPathFront $HOME/.local/bin
addToPathFront $HOME/.local/apps/
addToPathFront $N_PREFIX/bin:$PATH

# WSL appends all Windows %PATH% dirs (~460) to $PATH. Probing them over the 9p
# /mnt mount is slow — netrw :Ex took 2.6s, and git/fzf/mason executable lookups
# too. Strip /mnt/* from the shell PATH. Run Windows exes with `win <cmd>`, which
# re-adds the Windows PATH for that single call only.
path=("${(@)path:#/mnt/*}")
