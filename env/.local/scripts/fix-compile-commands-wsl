#!/usr/bin/env bash

if [ $# -ne 1 ]; then
  echo "Usage: $0 /mnt/c/path/to/compile_commands.json"
  exit 1
fi

# Input and output paths
INPUT="$1"
DIR=$(dirname "$INPUT")
OUTPUT="$DIR/compile_commands_wsl.json"

# Validate input file exists
if [ ! -f "$INPUT" ]; then
  echo "Error: File not found: $INPUT"
  exit 1
fi

# Process with jq
jq 'def winpath:
        gsub("(?<d>[A-Z]):"; "/mnt/\(.d | ascii_downcase)")
        | gsub("\\\\"; "/");
    map(
        . + {
            file: (.file | winpath),
            directory: (.directory | winpath),
            command: (.command | winpath)
        }
    )' "$INPUT" > "$OUTPUT"

echo "WSL-friendly compile_commands.json written to: $OUTPUT"

